{
  "version": "1.0.0",
  "agent": {
    "name": "androidforclaw",
    "defaultModel": "claude-opus-4-6",
    "maxIterations": 50
  },
  "thinking": {
    "enabled": true,
    "budgetTokens": 10000
  },
  "skills": {
    "bundledPath": "assets://skills/",
    "workspacePath": "/sdcard/AndroidForClaw/workspace/skills/",
    "autoLoad": ["mobile-operations"]
  },
  "gateway": {
    "enabled": true,
    "port": 8080,
    "security": {
      "requirePairing": true,
      "allowlist": []
    },
    "feishu": {
      "enabled": true,
      "appId": "YOUR_FEISHU_APP_ID",
      "appSecret": "YOUR_FEISHU_APP_SECRET",
      "encryptKey": "YOUR_ENCRYPT_KEY",
      "verificationToken": "YOUR_VERIFICATION_TOKEN",
      "domain": "feishu",
      "connectionMode": "websocket",
      "dmPolicy": "open",
      "allowFrom": [],
      "groupPolicy": "open",
      "groupAllowFrom": [],
      "requireMention": true,
      "groupCommandMentionBypass": "never",
      "allowMentionlessInMultiBotGroup": false,
      "historyLimit": 20,
      "dmHistoryLimit": 100,
      "textChunkLimit": 4000,
      "chunkMode": "length",
      "mediaMaxMb": 20.0,
      "typingIndicator": true,
      "reactionDedup": true,
      "debugMode": false
    },
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "name": "AndroidForClaw Bot",
      "dm": {
        "policy": "open",
        "allowFrom": []
      },
      "groupPolicy": "open",
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": true,
          "channels": []
        }
      },
      "replyToMode": "off"
    }
  }
}
