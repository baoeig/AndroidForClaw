<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- 背景圆形渐变 -->
  <group
      android:translateX="54"
      android:translateY="54">

    <!-- 外圈光晕效果 -->
    <path
        android:pathData="M 0,0 m -32,0 a 32,32 0 1,0 64,0 a 32,32 0 1,0 -64,0"
        android:fillColor="#4A90E2"
        android:fillAlpha="0.2"/>

    <!-- 主圆形背景 -->
    <path
        android:pathData="M 0,0 m -28,0 a 28,28 0 1,0 56,0 a 28,28 0 1,0 -56,0"
        android:fillColor="#5B9BD5"/>

    <!-- 字母 A 的主体 - 简化现代设计 -->
    <group
        android:translateY="-2">
      <!-- A 的左边 -->
      <path
          android:pathData="M -12,-15 L -8,12 L -4,12 L 0,-15 Z"
          android:fillColor="#FFFFFF"/>

      <!-- A 的右边 -->
      <path
          android:pathData="M 0,-15 L 4,12 L 8,12 L 12,-15 Z"
          android:fillColor="#FFFFFF"/>

      <!-- A 的横杠 - 设计成爪痕效果 -->
      <path
          android:pathData="M -7,-2 L -5,-1 L 5,-1 L 7,-2 L 5,-3 L -5,-3 Z"
          android:fillColor="#70CFFF"/>

      <!-- 额外的爪痕装饰 -->
      <path
          android:pathData="M -6,1 L -4,3 L -3,2 L -5,0 Z"
          android:fillColor="#70CFFF"
          android:fillAlpha="0.8"/>
      <path
          android:pathData="M 3,2 L 5,4 L 6,3 L 4,1 Z"
          android:fillColor="#70CFFF"
          android:fillAlpha="0.8"/>
    </group>

    <!-- 底部爪子装饰 - 三个小爪印 -->
    <group
        android:translateY="18">
      <!-- 左爪 -->
      <path
          android:pathData="M -10,0 L -9,3 L -7,3 L -6,0 Z"
          android:fillColor="#70CFFF"
          android:fillAlpha="0.6"/>

      <!-- 中间爪 -->
      <path
          android:pathData="M -2,1 L -1,4 L 1,4 L 2,1 Z"
          android:fillColor="#70CFFF"
          android:fillAlpha="0.8"/>

      <!-- 右爪 -->
      <path
          android:pathData="M 6,0 L 7,3 L 9,3 L 10,0 Z"
          android:fillColor="#70CFFF"
          android:fillAlpha="0.6"/>
    </group>

    <!-- AI 科技感点缀 - 四个角的小点 -->
    <path
        android:pathData="M -18,-18 L -16,-16 L -18,-14 L -20,-16 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"/>
    <path
        android:pathData="M 18,-18 L 20,-16 L 18,-14 L 16,-16 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"/>

  </group>
</vector>
