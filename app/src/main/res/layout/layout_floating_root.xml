<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 顶部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/primary_color">

        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:text="停止测试"
            android:textSize="12sp"
            android:backgroundTint="@color/status_failed"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="缩小"
            android:textSize="12sp"
            android:backgroundTint="@android:color/darker_gray"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="暂停"
            android:layout_marginHorizontal="5dp"
            />
        <Button
            android:id="@+id/btnResume"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="恢复"
            />

    </LinearLayout>

    <!-- 自定义Tab导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_color">

        <Button
            android:id="@+id/btnTabChatHistory"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="执行轨迹"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:background="@drawable/tab_selected_background"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/btnTabTodos"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Todos"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:background="@drawable/tab_unselected_background"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/btnTabBugList"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="BugList"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:background="@drawable/tab_unselected_background"
            android:layout_margin="2dp" />

    </LinearLayout>

    <!-- 内容容器 -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

</LinearLayout> 